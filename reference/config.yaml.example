# Azure DevOps TUI Configuration
# Copy this file to ~/.config/azdo-tui/config.yaml and edit the values

# Azure DevOps organization name (required)
organization: your-org-name

# Azure DevOps project name(s) (required)
# Simple format (API name shown in UI):
#   projects:
#     - your-project-name
# With display names (friendly name shown in UI, API name used for requests):
#   projects:
#     - name: ugly-api-project-name
#       display_name: My Project
#     - simple-project
# Multiple projects (shows combined view with "Project" column):
projects:
  - your-project-name

# Polling interval in seconds (optional, default: 60)
polling_interval: 60

# Theme (optional, default: dark)
# Built-in themes: dark, gruvbox, nord, dracula, catppuccin, github
# Custom themes: Place JSON theme files in ~/.config/azdo-tui/themes/
# Example: If you have ~/.config/azdo-tui/themes/mytheme.json, use: theme: mytheme
theme: dark

# Metrics tab (opt-in, management dashboard). Disabled unless enabled: true.
# When enabled a fourth tab surfaces per-user WIP, stuck-item flags, and
# points-closed over the configured interval.
#
# metrics:
#   enabled: false
#   interval_days: 14            # window for "points closed" / velocity
#   active_stale_days: 3         # dwell in Active above this flags the item
#   rft_stale_days: 2            # dwell in Ready for Test above this flags the item
#   wip_limit: 4                 # in-flight strictly above this marks a user overloaded
#   run_one_shot_backfill: false # set true once to seed 90 days of history via /updates;
#                                # creates a marker file so it never runs twice. Delete
#                                # ~/.config/azdo-tui/.metrics-backfill-done to re-run.
#   states:                      # configurable state names (case-insensitive matching)
#     active: Active
#     ready_for_test: Ready for Test
#     closed: Closed
#   state_labels:                # optional column-header overrides; auto-derived from
#                                # state names when absent (e.g. "Ready for Test" → "rft")
#     active: active
#     ready_for_test: rft
#     closed: closed
